i className=\"social-icons\">\n                <a\n                    href=\"https://twitter.com/LucyLing24\"\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    className=\"icon-colour  home-social-icons\"\n                >\n                  <AiOutlineTwitter />\n                </a>\n              </li>\n              <li className=\"social-icons\">\n                <a\n                    href=\"https://www.linkedin.com/in/lucyling24\"\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    className=\"icon-colour  home-social-icons\"\n                >\n                  <FaLinkedinIn />\n                </a>\n              </li>\n              <li className=\"social-icons\">\n                <a\n                    href=\"https://www.zhihu.com/people/linglong24\"\n                    target=\"_blank\"\n                    rel=\"noreferrer\"\n                    className=\"icon-colour home-social-icons\"\n                >\n                  <AiOutlineZhihu />\n                </a>\n              </li>\n            </ul>\n            <p>\n              Feel free to <span className=\"purple\">connect </span>with me\n            </p>\n          </Col>\n        </Row>\n        <br/><br/>\n      </Container>\n    </Container>\n  );\n}\nexport default Home2;\n","/Users/lynnhoo/Documents/information/lucyling-portfolio-master/src/components/Home/Type.js",[],[],"/Users/lynnhoo/Documents/information/lucyling-portfolio-master/src/components/Gallery/Pictures.js",["124"],[],"import React from \"react\";\nimport p1 from '../../Assets/Gallery/1.png';\nimport p2 from'../../Assets/Gallery/2.png';\nimport p3 from'../../Assets/Gallery/3.png';\nimport p4 from'../../Assets/Gallery/4.png';\nimport p5 from'../../Assets/Gallery/5.png';\nimport p6 from'../../Assets/Gallery/6.png';\nimport p7 from'../../Assets/Gallery/7.png';\nimport p8 from'../../Assets/Gallery/8.png';\nimport p9 from'../../